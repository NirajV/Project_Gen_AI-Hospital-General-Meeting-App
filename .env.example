# ============================================================================
# Hospital Meeting Scheduler - Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# Usage: cp .env.example .env
# ============================================================================

# ============================================================================
# MySQL Database Configuration
# ============================================================================
MYSQL_ROOT_PASSWORD=rootpassword_change_in_production
MYSQL_DATABASE=hospital_meeting_scheduler
MYSQL_USER=hospital_user
MYSQL_PASSWORD=hospital_pass_change_in_production
MYSQL_PORT=3306

# ============================================================================
# Backend Configuration
# ============================================================================

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# CORS (Cross-Origin Resource Sharing)
# Add your production domains here
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================================
# Email Configuration (Optional but Recommended)
# ============================================================================

# Enable/disable email notifications
EMAIL_ENABLED=false

# SMTP Server Settings (Example: Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# How to get Gmail App Password:
# 1. Go to Google Account → Security
# 2. Enable 2-Step Verification
# 3. Go to App passwords
# 4. Generate password for "Mail"
# 5. Use the 16-character password here

# ============================================================================
# Application Configuration
# ============================================================================

# Application owner email (receives feedback submissions)
OWNER_EMAIL=Niraj.K.Vishwakarma@gmail.com

# Environment (development, staging, production)
ENVIRONMENT=development

# ============================================================================
# Service Ports (Default values, change if needed)
# ============================================================================
FRONTEND_PORT=3000
BACKEND_PORT=8001

# ============================================================================
# Frontend Configuration
# ============================================================================

# Backend API URL for frontend
# Production: https://api.yourdomain.com
# Development: http://localhost:8001
REACT_APP_BACKEND_URL=http://localhost:8001

# Node environment
NODE_ENV=production

# ============================================================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================================================

# Before deploying to production, make sure to:
# 
# 1. Security:
#    - Change MYSQL_ROOT_PASSWORD to a strong password
#    - Change MYSQL_PASSWORD to a strong password
#    - Generate a strong JWT_SECRET (32+ characters)
#    - Update CORS_ORIGINS to your production domain
#
# 2. Email:
#    - Set EMAIL_ENABLED=true
#    - Configure SMTP_USER and SMTP_PASSWORD
#
# 3. Database:
#    - Backup your database regularly
#    - Use encrypted connections (SSL/TLS)
#
# 4. Monitoring:
#    - Set up health check monitoring
#    - Configure log aggregation
#    - Enable database audit logging
#
# 5. SSL/HTTPS:
#    - Use SSL certificates (Let's Encrypt recommended)
#    - Configure reverse proxy (Nginx)
#    - Update REACT_APP_BACKEND_URL to https://
#
# ============================================================================

# Example Production Values (Template):
# MYSQL_ROOT_PASSWORD=Xy9$mK#pQ2nR7vB@wL5sT8jD
# MYSQL_PASSWORD=Hp4&tN*fG6mW9xC@yJ2eR5kV
# JWT_SECRET=aB3#dE6$fG9@hI2*jK5%lM8^nO1&pQ4
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://api.yourdomain.com
# EMAIL_ENABLED=true
# REACT_APP_BACKEND_URL=https://api.yourdomain.com
# NODE_ENV=production
# ENVIRONMENT=production

# ============================================================================
# End of Configuration
# ============================================================================
